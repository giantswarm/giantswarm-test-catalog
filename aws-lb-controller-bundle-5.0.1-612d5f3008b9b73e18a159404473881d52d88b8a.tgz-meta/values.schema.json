{
    "$schema": "http://json-schema.org/schema#",
    "type": "object",
    "additionalProperties": true,
    "properties": {
        "bundleNameOverride": {
            "type": "string"
        },
        "fullBundleNameOverride": {
            "type": "string"
        },
        "ociRepositoryUrl": {
            "type": "string"
        },
        "image": {
            "type": "object",
            "properties": {
                "name": {
                    "type": "string"
                },
                "pullPolicy": {
                    "type": "string"
                },
                "registry": {
                    "type": "string"
                },
                "tag": {
                    "type": "string"
                }
            }
        },
        "clusterName": {
            "type": "string"
        },
        "verticalPodAutoscaler": {
            "type": "object",
            "properties": {
                "enabled": {
                    "type": "boolean"
                }
            }
        },
        "global": {
            "type": "object",
            "properties": {
                "podSecurityStandards": {
                    "type": "object",
                    "properties": {
                        "enforced": {
                            "type": "boolean"
                        }
                    }
                }
            }
        }
    }
}

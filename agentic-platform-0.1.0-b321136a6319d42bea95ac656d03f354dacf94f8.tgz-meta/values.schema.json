{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/giantswarm/agentic-platform/helm/agentic-platform/values.schema.json",
  "type": "object",
  "additionalProperties": true,
  "properties": {
    "global": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "registry": {
          "type": "string",
          "description": "Default container image registry. Override to point at a private mirror."
        },
        "imagePullSecrets": {
          "type": "array",
          "items": { "type": "object" }
        }
      }
    },
    "gateway": {
      "type": "object",
      "required": ["name", "gatewayClassName"],
      "additionalProperties": false,
      "properties": {
        "enabled": { "type": "boolean" },
        "name": { "type": "string", "minLength": 1 },
        "gatewayClassName": { "type": "string", "minLength": 1 },
        "listeners": {
          "type": "array",
          "items": { "type": "object" }
        },
        "parameters": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "enabled": { "type": "boolean" },
            "name": { "type": "string" },
            "serviceType": {
              "type": "string",
              "enum": ["ClusterIP", "NodePort", "LoadBalancer"],
              "description": "Service type for the data-plane Service. Default ClusterIP — the controller hardcodes LoadBalancer; this overlay forces the override."
            },
            "podSecurityContext": { "type": "object" },
            "containerSecurityContext": { "type": "object" },
            "dataPlaneEnv": {
              "type": "array",
              "items": { "type": "object" }
            },
            "dataPlaneVolumes": {
              "type": "array",
              "items": { "type": "object" }
            },
            "dataPlaneVolumeMounts": {
              "type": "array",
              "items": { "type": "object" }
            }
          }
        }
      }
    },
    "extraObjects": {
      "type": "array",
      "items": { "type": "object" },
      "description": "Arbitrary manifests rendered through `tpl` alongside the umbrella's templates. Each entry is any Kubernetes object."
    },
    "klaus-gateway": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "enabled": { "type": "boolean" }
      }
    },
    "klaus-operator": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "enabled": { "type": "boolean" }
      }
    },
    "networkPolicy": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "enabled": { "type": "boolean" },
        "flavor": { "type": "string", "enum": ["cilium", "kubernetes"] },
        "additionalEgressCIDRs": {
          "type": "array",
          "items": { "type": "string" }
        },
        "additionalEgressFQDNs": {
          "type": "array",
          "items": { "type": "object" },
          "description": "cilium flavor only — vanilla NetworkPolicy has no FQDN equivalent."
        },
        "kubernetes": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "apiServerCIDR": { "type": "string" },
            "worldExcludedCIDRs": {
              "type": "array",
              "items": { "type": "string" }
            }
          }
        }
      }
    }
  },
  "allOf": [
    {
      "description": "Bundled Valkey requires `valkey.enabled: true` together with `muster.muster.oauth.server.storage.type: valkey`. Conversely, switching muster's storage to valkey requires either the bundled `valkey.enabled: true` or an external `muster.muster.oauth.server.storage.valkey.url`.",
      "if": {
        "properties": {
          "muster": {
            "properties": {
              "muster": {
                "properties": {
                  "oauth": {
                    "properties": {
                      "server": {
                        "properties": {
                          "storage": {
                            "properties": {
                              "type": { "const": "valkey" }
                            },
                            "required": ["type"]
                          }
                        }
                      }
                    }
                  }
                }
              }
            }
          }
        }
      },
      "then": {
        "anyOf": [
          {
            "properties": {
              "valkey": {
                "properties": { "enabled": { "const": true } },
                "required": ["enabled"]
              }
            },
            "required": ["valkey"]
          },
          {
            "properties": {
              "muster": {
                "properties": {
                  "muster": {
                    "properties": {
                      "oauth": {
                        "properties": {
                          "server": {
                            "properties": {
                              "storage": {
                                "properties": {
                                  "valkey": {
                                    "properties": {
                                      "url": { "type": "string", "minLength": 1 }
                                    },
                                    "required": ["url"]
                                  }
                                }
                              }
                            }
                          }
                        }
                      }
                    }
                  }
                }
              }
            }
          }
        ]
      }
    }
  ]
}

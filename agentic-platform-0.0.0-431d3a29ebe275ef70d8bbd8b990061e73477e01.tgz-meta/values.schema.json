{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/giantswarm/agentic-platform/helm/agentic-platform/values.schema.json",
  "type": "object",
  "additionalProperties": true,
  "properties": {
    "global": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "registry": {
          "type": "string",
          "description": "Default container image registry. Override to point at a private mirror."
        },
        "imagePullSecrets": {
          "type": "array",
          "items": { "type": "object" }
        }
      }
    },
    "gateway": {
      "type": "object",
      "required": ["name", "gatewayClassName"],
      "additionalProperties": false,
      "properties": {
        "enabled": { "type": "boolean" },
        "name": { "type": "string", "minLength": 1 },
        "gatewayClassName": { "type": "string", "minLength": 1 },
        "listeners": {
          "type": "array",
          "items": { "type": "object" }
        },
        "parameters": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "enabled": { "type": "boolean" },
            "name": { "type": "string" },
            "podSecurityContext": { "type": "object" },
            "containerSecurityContext": { "type": "object" },
            "dataPlaneEnv": {
              "type": "array",
              "items": { "type": "object" },
              "description": "Strategic-merge env entries appended to the data-plane container. Each item is a corev1.EnvVar."
            },
            "dataPlaneVolumes": {
              "type": "array",
              "items": { "type": "object" },
              "description": "Strategic-merge volumes on the data-plane pod template. Each item is a corev1.Volume."
            },
            "dataPlaneVolumeMounts": {
              "type": "array",
              "items": { "type": "object" },
              "description": "Strategic-merge volumeMounts on the data-plane container. Each item is a corev1.VolumeMount."
            }
          }
        }
      }
    },
    "bootstrap": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "oauth": {
          "type": "object",
          "additionalProperties": false,
          "required": ["enabled", "name"],
          "properties": {
            "enabled": { "type": "boolean" },
            "name": { "type": "string", "minLength": 1 },
            "dexClientSecret": { "type": "string" }
          }
        }
      }
    },
    "networkPolicy": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "enabled": { "type": "boolean" },
        "flavor": { "type": "string", "enum": ["cilium", "none"] },
        "additionalEgressCIDRs": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Extra CIDR-based egress rules applied to the data-plane policy. Use for in-cluster Gateway VIPs whose Cilium identity doesn't match `cluster` or `world`."
        },
        "additionalEgressFQDNs": {
          "type": "array",
          "items": { "type": "object" },
          "description": "Extra FQDN-based egress rules. Requires a cluster-wide Cilium DNS visibility policy. Each item is a Cilium FQDN selector (e.g. {matchName: dex.example.com})."
        }
      }
    }
  },
  "allOf": [
    {
      "description": "Bundled Valkey requires `valkey.enabled: true` together with `muster.muster.oauth.server.storage.type: valkey`. Conversely, switching muster's storage to valkey requires either the bundled `valkey.enabled: true` or an external `muster.muster.oauth.server.storage.valkey.url`.",
      "if": {
        "properties": {
          "muster": {
            "properties": {
              "muster": {
                "properties": {
                  "oauth": {
                    "properties": {
                      "server": {
                        "properties": {
                          "storage": {
                            "properties": {
                              "type": { "const": "valkey" }
                            },
                            "required": ["type"]
                          }
                        }
                      }
                    }
                  }
                }
              }
            }
          }
        }
      },
      "then": {
        "anyOf": [
          {
            "properties": {
              "valkey": {
                "properties": { "enabled": { "const": true } },
                "required": ["enabled"]
              }
            },
            "required": ["valkey"]
          },
          {
            "properties": {
              "muster": {
                "properties": {
                  "muster": {
                    "properties": {
                      "oauth": {
                        "properties": {
                          "server": {
                            "properties": {
                              "storage": {
                                "properties": {
                                  "valkey": {
                                    "properties": {
                                      "url": { "type": "string", "minLength": 1 }
                                    },
                                    "required": ["url"]
                                  }
                                }
                              }
                            }
                          }
                        }
                      }
                    }
                  }
                }
              }
            }
          }
        ]
      }
    }
  ]
}

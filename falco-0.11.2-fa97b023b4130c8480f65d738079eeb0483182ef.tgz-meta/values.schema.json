{
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "properties": {
        "ciliumNetworkPolicy": {
            "properties": {
                "enabled": {
                    "type": "boolean"
                }
            },
            "type": "object"
        },
        "falco": {
            "properties": {
                "collectors": {
                    "properties": {
                        "kubernetes": {
                            "properties": {
                                "enabled": {
                                    "type": "boolean"
                                }
                            },
                            "type": "object"
                        }
                    },
                    "type": "object"
                },
                "controller": {
                    "properties": {
                        "labels": {
                            "properties": {
                                "application.giantswarm.io/team": {
                                    "type": "string"
                                }
                            },
                            "type": "object"
                        }
                    },
                    "type": "object"
                },
                "customRules": {
                    "properties": {
                        "gs-root-ca-key-access.yaml": {
                            "type": "string"
                        }
                    },
                    "type": "object"
                },
                "driver": {
                    "properties": {
                        "kind": {
                            "type": "string"
                        },
                        "loader": {
                            "properties": {
                                "initContainer": {
                                    "properties": {
                                        "image": {
                                            "properties": {
                                                "registry": {
                                                    "type": "string"
                                                },
                                                "repository": {
                                                    "type": "string"
                                                }
                                            },
                                            "type": "object"
                                        }
                                    },
                                    "type": "object"
                                }
                            },
                            "type": "object"
                        }
                    },
                    "type": "object"
                },
                "falco": {
                    "properties": {
                        "grpc": {
                            "properties": {
                                "enabled": {
                                    "type": "boolean"
                                }
                            },
                            "type": "object"
                        },
                        "grpc_output": {
                            "properties": {
                                "enabled": {
                                    "type": "boolean"
                                }
                            },
                            "type": "object"
                        },
                        "webserver": {
                            "properties": {
                                "enabled": {
                                    "type": "boolean"
                                },
                                "prometheus_metrics_enabled": {
                                    "type": "boolean"
                                }
                            },
                            "type": "object"
                        }
                    },
                    "type": "object"
                },
                "falcoctl": {
                    "properties": {
                        "image": {
                            "properties": {
                                "registry": {
                                    "type": "string"
                                },
                                "repository": {
                                    "type": "string"
                                }
                            },
                            "type": "object"
                        }
                    },
                    "type": "object"
                },
                "image": {
                    "properties": {
                        "registry": {
                            "type": "string"
                        },
                        "repository": {
                            "type": "string"
                        }
                    },
                    "type": "object"
                },
                "k8s-metacollector": {
                    "properties": {
                        "fullnameOverride": {
                            "type": "string"
                        },
                        "service": {
                            "properties": {
                                "ports": {
                                    "properties": {
                                        "broker-grpc": {
                                            "properties": {
                                                "port": {
                                                    "type": "integer"
                                                }
                                            },
                                            "type": "object"
                                        }
                                    },
                                    "type": "object"
                                }
                            },
                            "type": "object"
                        }
                    },
                    "type": "object"
                },
                "metrics": {
                    "properties": {
                        "enabled": {
                            "type": "boolean"
                        },
                        "outputRule": {
                            "type": "boolean"
                        }
                    },
                    "type": "object"
                },
                "podPriorityClassName": {
                    "type": "string"
                },
                "serviceAccount": {
                    "properties": {
                        "name": {
                            "type": "string"
                        }
                    },
                    "type": "object"
                },
                "serviceMonitor": {
                    "properties": {
                        "create": {
                            "type": "boolean"
                        },
                        "labels": {
                            "properties": {
                                "application.giantswarm.io/team": {
                                    "type": "string"
                                }
                            },
                            "type": "object"
                        }
                    },
                    "type": "object"
                },
                "tolerations": {
                    "items": {
                        "properties": {
                            "effect": {
                                "type": "string"
                            },
                            "key": {
                                "type": "string"
                            }
                        },
                        "type": "object"
                    },
                    "type": "array"
                },
                "tty": {
                    "type": "boolean"
                }
            },
            "type": "object"
        },
        "falcosidekick": {
            "properties": {
                "image": {
                    "properties": {
                        "registry": {
                            "type": "string"
                        },
                        "repository": {
                            "type": "string"
                        }
                    },

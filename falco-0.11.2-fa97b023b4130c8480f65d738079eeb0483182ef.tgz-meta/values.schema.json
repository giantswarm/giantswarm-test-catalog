                }
            },
            "type": "object"
        },
        "global": {
            "properties": {
                "podSecurityStandards": {
                    "properties": {
                        "enforced": {
                            "type": "boolean"
                        }
                    },
                    "type": "object"
                }
            },
            "type": "object"
        },
        "k8s-metacollector": {
            "properties": {
                "image": {
                    "properties": {
                        "registry": {
                            "type": "string"
                        },
                        "repository": {
                            "type": "string"
                        }
                    },
                    "type": "object"
                }
            },
            "type": "object"
        },
        "kyvernoPolicyExceptions": {
            "properties": {
                "enabled": {
                    "type": "boolean"
                },
                "namespace": {
                    "type": "string"
                }
            },
            "type": "object"
        },
        "verticalPodAutoscaler": {
            "properties": {
                "enabled": {
                    "type": "boolean"
                }
            },
            "type": "object"
        }
    },
    "type": "object"
}

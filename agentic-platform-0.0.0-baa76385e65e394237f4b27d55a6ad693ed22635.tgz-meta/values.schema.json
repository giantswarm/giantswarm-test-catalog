{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/giantswarm/agentic-platform/helm/agentic-platform/values.schema.json",
  "type": "object",
  "additionalProperties": true,
  "properties": {
    "global": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "registry": {
          "type": "string",
          "description": "Default container image registry. Override to point at a private mirror."
        },
        "imagePullSecrets": {
          "type": "array",
          "items": { "type": "object" }
        }
      }
    },
    "gateway": {
      "type": "object",
      "required": ["name", "gatewayClassName"],
      "additionalProperties": false,
      "properties": {
        "enabled": { "type": "boolean" },
        "name": { "type": "string", "minLength": 1 },
        "gatewayClassName": { "type": "string", "minLength": 1 },
        "listeners": {
          "type": "array",
          "items": { "type": "object" }
        },
        "parameters": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "enabled": { "type": "boolean" },
            "name": { "type": "string" },
            "podSecurityContext": { "type": "object" },
            "containerSecurityContext": { "type": "object" },
            "dataPlaneEnv": {
              "type": "array",
              "items": { "type": "object" },
              "description": "Strategic-merge env entries appended to the data-plane container. Each item is a corev1.EnvVar."
            },
            "dataPlaneVolumes": {
              "type": "array",
              "items": { "type": "object" },
              "description": "Strategic-merge volumes on the data-plane pod template. Each item is a corev1.Volume."
            },
            "dataPlaneVolumeMounts": {
              "type": "array",
              "items": { "type": "object" },
              "description": "Strategic-merge volumeMounts on the data-plane container. Each item is a corev1.VolumeMount."
            }
          }
        }
      }
    },
    "networkPolicy": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "enabled": { "type": "boolean" },
        "flavor": { "type": "string", "enum": ["cilium", "none"] }
      }
    }
  }
}

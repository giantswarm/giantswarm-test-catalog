{
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "type": "object",
    "properties": {
        "agentgateway": {
            "type": "object",
            "properties": {
                "enabled": {
                    "type": "boolean"
                },
                "gateway": {
                    "type": "object",
                    "properties": {
                        "name": {
                            "type": "string"
                        }
                    },
                    "additionalProperties": false
                },
                "host": {
                    "type": "string"
                },
                "ingressGateway": {
                    "type": "object",
                    "properties": {
                        "name": {
                            "type": "string"
                        },
                        "namespace": {
                            "type": "string"
                        }
                    },
                    "additionalProperties": false
                },
                "jwt": {
                    "type": "object",
                    "properties": {
                        "audiences": {
                            "type": "array",
                            "items": {
                                "type": "string"
                            }
                        },
                        "issuer": {
                            "type": "string"
                        },
                        "jwksBackendRef": {
                            "type": "object",
                            "properties": {
                                "name": {
                                    "type": "string"
                                },
                                "namespace": {
                                    "type": "string"
                                },
                                "port": {
                                    "type": "integer"
                                }
                            },
                            "additionalProperties": false
                        },
                        "jwksPath": {
                            "type": "string"
                        }
                    },
                    "additionalProperties": false
                },
                "musterHost": {
                    "type": "string"
                },
                "musterUrl": {
                    "type": "string"
                },
                "oauthMode": {
                    "type": "string",
                    "enum": [
                        "validate",
                        "passthrough"
                    ]
                },
                "tokenExchange": {
                    "type": "object",
                    "properties": {
                        "broker": {
                            "type": "object",
                            "properties": {
                                "kind": {
                                    "type": "string"
                                },
                                "name": {
                                    "type": "string"
                                },
                                "namespace": {
                                    "type": "string"
                                },
                                "port": {
                                    "type": "integer"
                                },
                                "protocol": {
                                    "type": "string"
                                }
                            },
                            "additionalProperties": false
                        }
                    },
                    "additionalProperties": false
                },
                "viaMuster": {
                    "type": "boolean"
                }
            },
            "additionalProperties": false
        },
        "defaults": {
            "type": "object",
            "properties": {
                "audiences": {
                    "type": "array",
                    "items": {
                        "type": "string"
                    }
                },
                "autoStart": {
                    "type": "boolean"
                },
                "transport": {
                    "type": "string"
                }
            },
            "additionalProperties": false
        },
        "global": {
            "description": "Global values shared between all subcharts",
            "$comment": "Added automatically by 'helm schema' to allow this chart to be used as a Helm dependency, as the `additionalProperties` setting would otherwise collide with Helm's special 'global' values key.",
            "type": [
                "object",
                "null"
            ]
        },
        "identityProviders": {
            "type": "object",
            "additionalProperties": false
        },
        "mcpServers": {
            "type": "array"
        },
        "muster": {
            "type": "object",
            "properties": {
                "enabled": {
                    "type": "boolean"
                },
                "families": {
                    "type": "object",
                    "properties": {
                        "kubernetes": {
                            "type": "object",
                            "properties": {
                                "instanceArg": {
                                    "type": "string"
                                }
                            },
                            "additionalProperties": false
                        },
                        "prometheus": {
                            "type": "object",
                            "properties": {
                                "instanceArg": {
                                    "type": "string"
                                }
                            },
                            "additionalProperties": false
                        }
                    },
                    "additionalProperties": false
                }
            },
            "additionalProperties": false
        }
    },
    "additionalProperties": false
}

{
  "$schema": "http://json-schema.org/schema#",
  "type": "object",
  "properties": {
    "image": {
      "type": "object",
      "properties": {
        "registry": { "type": "string" },
        "name": { "type": "string" },
        "tag": { "type": "string" }
      }
    },
    "route": {
      "type": "object",
      "properties": {
        "enabled": { "type": "boolean" },
        "hostnames": {
          "type": "array",
          "items": { "type": "string" }
        },
        "parentRefs": {
          "type": "array",
          "items": { "type": "object" }
        }
      }
    }
  }
}
